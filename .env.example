# ccvoice .env (复制为 .env 后填值，并 chmod 600)
#
# Cloudflare Tunnel token — 自托管 relay 才需要；用 ccvoice.app 公共 relay 不需要
# 申请位置: https://one.dash.cloudflare.com/ → Networks → Tunnels
TUNNEL_TOKEN=

# Claude Code 默认工作目录（可被 --project 覆盖）
CLAUDE_CWD=

# Claude 模型（可被 --model 覆盖）
CLAUDE_MODEL=sonnet

# Claude 权限模式（不建议改；默认 default。用 --unsafe flag 启用 bypassPermissions）
# CLAUDE_PERMISSION_MODE=default
